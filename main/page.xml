      <onCreate><![CDATA[const observer = new ResizeObserver(entries => {
    for (let entry of entries) {
        //const width = entry.contentRect.width;
        //const height = entry.contentRect.height;
        if (!sender.img) return;
        let r = eb.getDivRectSetting(sender);
        let ratio = sender.img.naturalHeight / sender.img.naturalWidth;
        let thisW, thisH;
        if (sender.resizeMode == "width") {
            thisW = r.w;
            thisH = parseInt(thisW * ratio);
        } else {
            thisH = r.h;
            thisW = parseInt(thisH / ratio);
        }
        if ((thisW == r.w) &amp;&amp; (thisH == r.h)) return;
        if (sender.resizeMode == "width") {
            ee.setRect(sender, null, null, null, thisH);
        } else {
            ee.setRect(sender, null, null, thisW, null);
        }
        eb.processDock();
    }
});
observer.observe(sender);
]]></onCreate>
